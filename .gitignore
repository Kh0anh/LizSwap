# ============================================================
# LizSwap – .gitignore
# ============================================================

# ------------------------------------------------------------
# Dependencies
# ------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# ------------------------------------------------------------
# Build outputs
# ------------------------------------------------------------
dist/
build/
out/
.next/
*.tsbuildinfo

# ------------------------------------------------------------
# Environment variables (chứa secrets)
# ------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example được track (template)

# ------------------------------------------------------------
# Foundry / Smart Contracts
# ------------------------------------------------------------
contracts/cache/
contracts/out/
contracts/broadcast/

# ------------------------------------------------------------
# Docker (generated data)
# ------------------------------------------------------------
infra/certbot/conf/
infra/certbot/www/

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ------------------------------------------------------------
# Testing & Coverage
# ------------------------------------------------------------
coverage/
.nyc_output/

# ------------------------------------------------------------
# IDE / Editor
# ------------------------------------------------------------
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ------------------------------------------------------------
# OS files
# ------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ------------------------------------------------------------
# Misc
# ------------------------------------------------------------
*.tgz
.cache/
.turbo/
