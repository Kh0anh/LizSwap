# ============================================================
# LizSwap – Docker Environment Configuration
# ============================================================
# Copy file này sang .env và điền thông tin thực tế:
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------
POSTGRES_USER=lizswap
POSTGRES_PASSWORD=lizswap_secret_change_me
POSTGRES_DB=lizswap
POSTGRES_PORT=5432

# Connection string (dùng trong backend/indexer)
DATABASE_URL=postgresql://lizswap:lizswap_secret_change_me@postgres:5432/lizswap

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# ------------------------------------------------------------
# BSC RPC Endpoints
# Có thể dùng QuickNode, Ankr, hoặc BSC Public RPC
# ------------------------------------------------------------
# HTTPS RPC (cho readContract, eth_call)
BSC_RPC_URL=https://bsc-testnet-rpc.publicnode.com

# WebSocket RPC (cho Indexer subscribe events)
BSC_RPC_WS=wss://bsc-testnet-rpc.publicnode.com

# Chain ID: 56 = Mainnet, 97 = Testnet
BSC_CHAIN_ID=97

# ------------------------------------------------------------
# Smart Contract Addresses (deploy thủ công bằng Foundry)
# Điền địa chỉ sau khi deploy contracts lên BSC
# ------------------------------------------------------------
FACTORY_ADDR=0x0000000000000000000000000000000000000000
ROUTER_ADDR=0x0000000000000000000000000000000000000000
STAKING_ADDR=0x0000000000000000000000000000000000000000

# WBNB address (BSC Testnet)
WBNB_ADDR=0xae13d989daC2f0dEbFf460aC112a837C89BAa7cd

# ------------------------------------------------------------
# JWT Authentication
# ------------------------------------------------------------
JWT_SECRET=your_jwt_secret_change_me_to_random_string
JWT_EXPIRES_IN=24h

# ------------------------------------------------------------
# Initial Manager Wallet (seed vào DB khi khởi tạo)
# ------------------------------------------------------------
MANAGER_WALLET=0x070714e05b45f236FeAe2A87Cb1A740fAfA047B4

# ------------------------------------------------------------
# Domain Configuration
# ------------------------------------------------------------
DOMAIN=lizswap.xyz
ADMIN_DOMAIN=admin.lizswap.xyz

# Email cho Certbot (Let's Encrypt)
CERTBOT_EMAIL=admin@lizswap.xyz

# ------------------------------------------------------------
# Frontend Public Environment Variables
# (cần tại build time cho Next.js)
# ------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://lizswap.xyz/api
NEXT_PUBLIC_WS_URL=wss://lizswap.xyz/ws
NEXT_PUBLIC_FACTORY_ADDR=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ROUTER_ADDR=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_STAKING_ADDR=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_CHAIN_ID=97

# ------------------------------------------------------------
# Indexer Configuration
# ------------------------------------------------------------
INDEXER_POLL_INTERVAL_MS=2000
INDEXER_START_BLOCK=latest

# ------------------------------------------------------------
# Node Environment
# ------------------------------------------------------------
NODE_ENV=production
